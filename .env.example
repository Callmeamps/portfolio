# ── OCI Object Storage — Contact Form ──
# Pre-authenticated request URLs for the contact-submissions bucket.
# DO NOT commit these to version control — add to .env.local only.
#
# How to get these:
#   1. oci os preauth-request create --namespace-name axygpftmwvrk \
#        --bucket-name contact-submissions --name contact-write-sub \
#        --access-type ObjectWrite --object-name "submissions/" \
#        --time-expires 2027-01-01T00:00:00Z
#   2. oci os preauth-request create --namespace-name axygpftmwvrk \
#        --bucket-name contact-submissions --name contact-read-idx \
#        --access-type ObjectRead --object-name submissions_index.json \
#        --time-expires 2027-01-01T00:00:00Z
#   3. oci os preauth-request create --namespace-name axygpftmwvrk \
#        --bucket-name contact-submissions --name contact-write-idx \
#        --access-type ObjectWrite --object-name submissions_index.json \
#        --time-expires 2027-01-01T00:00:00Z

# Write submissions to bucket (PUT to submissions/<id>.json)
# OCI_CONTACT_WRITE_PAR=

# Read the submissions index (GET submissions_index.json)
# OCI_CONTACT_READ_PAR=

# Write to the index (PUT submissions_index.json for updating the list)
# OCI_CONTACT_WRITE_INDEX_PAR=

# Optional: Bearer token for /api/contact GET endpoint (list submissions)
# CONTACT_API_TOKEN=